{
  "name": "nextjs-static-blog",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "prebuild": "npm run generate",
    "generate": "npm run generate:metadata && npm run generate:images && npm run generate:redirects",
    "generate:metadata": "tsx scripts/generate-metadata.ts",
    "generate:images": "tsx scripts/optimise-images.ts",
    "generate:redirects": "tsx scripts/generate-redirects.ts",
    "generate:sitemap": "tsx scripts/generate-sitemap.ts",
    "generate:robots": "tsx scripts/generate-robots.ts",
    "generate:rss": "tsx scripts/generate-rss.ts",
    "postbuild": "npm run generate:sitemap && npm run generate:robots && npm run generate:rss",
    "build": "next build",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "start": "next start"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.555.0",
    "next": "^16.2.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-icons": "^5.6.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-external-links": "^3.0.0",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-html": "^16.0.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "baseline-browser-mapping": "^2.10.20",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "postcss": "^8.5.10",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.18",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
